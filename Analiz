<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>VIP NEON ANALİZ & TELEGRAM</title>
    <style>
        /* CANLI ARKA PLAN VE IŞILTI EFEKTİ */
        body { 
            background: #0a0412; 
            color: white; font-family: 'Arial Black', sans-serif; 
            margin: 0; padding: 0; display: flex; flex-direction: column; align-items: center;
            overflow-x: hidden;
            background-image: linear-gradient(to bottom, rgba(88, 24, 255, 0.2) 0%, transparent 100%);
        }

        /* Yukarıdan aşağıya akan parıltı animasyonu */
        .parilti-katmani {
            position: fixed; top: -100%; left: 0; width: 100%; height: 200%;
            background: linear-gradient(to bottom, transparent, rgba(0, 255, 136, 0.15), transparent);
            animation: akis 4s linear infinite; z-index: -1; pointer-events: none;
        }
        @keyframes akis { 0% { top: -100%; } 100% { top: 100%; } }

        /* NEON SPONSOR KARTLARI */
        .sponsor-grid {
            display: grid; grid-template-columns: repeat(3, 1fr);
            gap: 8px; width: 98%; padding: 15px 0;
        }
        .neon-link {
            background: rgba(0, 0, 0, 0.8); border-radius: 12px; 
            padding: 12px 2px; text-align: center; border: 2px solid; 
            text-decoration: none; color: white; transition: 0.3s;
            display: flex; flex-direction: column; align-items: center;
        }
        .l-banko { border-color: #ff00ff; box-shadow: 0 0 15px #ff00ff; }
        .l-cratos { border-color: #ffcc00; box-shadow: 0 0 15px #ffcc00; }
        .l-beygir { border-color: #00ccff; box-shadow: 0 0 15px #00ccff; }
        
        .neon-link img { width: 55px; height: 55px; object-fit: contain; margin-bottom: 5px; border-radius: 8px; }
        .slogan-ana { font-size: 11px; font-weight: 900; color: #fff; margin-bottom: 2px; display: block; text-transform: uppercase; }
        .slogan-alt { font-size: 9px; font-weight: bold; color: #00ff88; display: block; }

        /* ANALİZ PANELİ */
        .analiz-panel {
            width: 94%; background: rgba(20, 10, 40, 0.9);
            border: 2px solid #00ff88; border-radius: 20px;
            margin: 10px 0; padding: 20px 0; text-align: center;
            box-shadow: 0 0 25px rgba(0, 255, 136, 0.4);
            position: relative;
        }
        .panel-baslik { font-size: 12px; color: #00ff88; letter-spacing: 3px; font-weight: bold; }
        #sonuc { font-size: 44px; font-weight: 900; color: #fff; text-shadow: 0 0 20px #00ff88; margin-top: 5px; }

        /* TELEGRAM BUTONU (ANALİZ ALTINA) */
        .tg-link {
            display: inline-block; margin-top: 15px; width: 85%;
            background: #24A1DE; color: white; text-decoration: none;
            padding: 10px; border-radius: 50px; font-size: 13px; font-weight: 900;
            border: 2px solid #fff; box-shadow: 0 0 15px #24A1DE;
            animation: pulse 2s infinite;
        }
        @keyframes pulse { 0% { transform: scale(1); } 50% { transform: scale(1.05); } 100% { transform: scale(1); } }

        /* SAYI TABLOSU */
        .table-area { width: 100%; display: flex; justify-content: center; padding: 15px 0; }
        .grid-rulet {
            display: grid; grid-template-columns: 45px repeat(12, 1fr);
            gap: 3px; width: 98%; max-width: 420px;
        }
        .hucre {
            height: 45px; display: flex; align-items: center; justify-content: center;
            font-size: 18px; font-weight: bold; border: 1px solid rgba(255,255,255,0.2);
            position: relative; border-radius: 5px; cursor: pointer;
        }
        .sifir { background: #008148; grid-row: span 3; height: 100%; }
        .kirmizi { background: #b91d1d; }
        .siyah { background: #111; }
        
        /* KAFA SAYI (ALTIN PARA) */
        .para {
            position: absolute; width: 28px; height: 28px;
            background: radial-gradient(circle, #fff700, #ff8c00);
            border-radius: 50%; border: 2px solid #fff;
            box-shadow: 0 0 15px #ffcc00; display: none; z-index: 50;
            animation: bounce 0.6s infinite alternate;
        }
        @keyframes bounce { from { transform: scale(1); } to { transform: scale(1.2); } }

        /* ALT BANNER */
        .footer-banner {
            width: 94%; background: linear-gradient(90deg, #4a148c, #1a0b2e);
            padding: 15px; border-radius: 12px; margin: 20px 0;
            text-align: center; font-size: 20px; font-weight: 900; 
            border: 2px solid #00ff88; color: #fff; text-shadow: 0 0 15px #00ff88;
        }
    </style>
</head>
<body>

    <div class="parilti-katmani"></div>

    <div class="sponsor-grid">
        <a href="https://cutt.ly/MtyvmK60" target="_blank" class="neon-link l-banko">
            <img src="https://i.ibb.co/mS09X4y/banko.jpg" alt="Banko">
            <span class="slogan-ana">BANKOBET</span>
            <span class="slogan-alt">383 FS DENEME</span>
        </a>
        <a href="https://cutt.ly/ruletcsn" target="_blank" class="neon-link l-cratos">
            <img src="https://i.ibb.co/v4mK60M/cratos.jpg" alt="Cratos">
            <span class="slogan-ana">CRATOS ROYAL</span>
            <span class="slogan-alt">1000 TL DENEME</span>
        </a>
        <a href="https://t2m.io/bygrruletcsn" target="_blank" class="neon-link l-beygir">
            <img src="https://i.ibb.co/7N6v6Ym/beygir.jpg" alt="Beygir">
            <span class="slogan-ana">BEYGİRBET</span>
            <span class="slogan-alt">%100 ÇEVRİMSİZ</span>
        </a>
    </div>

    <div class="analiz-panel">
        <div class="panel-baslik">STRATEJİK ANALİZ VERİSİ</div>
        <div id="sonuc">SAYI SEÇİN</div>
        
        <a href="https://t.me/casinotabutt" target="_blank" class="tg-link">
            📢 TELEGRAM SOHBET KANALIMIZ
        </a>
    </div>

    <div class="table-area">
        <div class="grid-rulet" id="ruletBoard">
            <div class="hucre sifir" onclick="analizEt(0)">0<div class="para" id="p-0"></div></div>
        </div>
    </div>

    <div class="footer-banner">🍀 BOL ŞANS DİLERİM 🍀</div>

    <script>
        const veriler = {
            0:"18-24-36", 1:"11-12-21", 2:"17-18-24", 3:"4-9-23", 4:"5-6-7", 5:"20-25-35", 6:"4-12-16", 7:"4-14-27", 
            8:"1-21-35", 9:"19-28-36", 10:"0-25-29", 11:"21-22-24", 12:"1-21-36", 13:"9-17-26", 14:"23-28-32", 15:"0-8-31", 
            16:"6-28-32", 17:"2-22-35", 18:"19-31-36", 19:"29-32-36", 20:"9-21-35", 21:"11-12-20", 22:"23-25-26", 23:"6-18-32", 
            24:"4-7-26", 25:"0-7-14", 26:"10-13-31", 27:"9-12-19", 28:"4-14-28", 29:"11-22-33", 30:"15-31-35", 31:"5-26-34", 
            32:"3-9-23", 33:"4-11-22", 34:"12-21-31", 35:"4-9-27", 36:"16-19-29"
        };

        const kirmizilar = [1,3,5,7,9,12,14,16,19,21,23,25,27,30,32,34,36];
        const satirDuzen = [[3,6,9,12,15,18,21,24,27,30,33,36],[2,5,8,11,14,17,20,23,26,29,32,35],[1,4,7,10,13,16,19,22,25,28,31,34]];
        const tahta = document.getElementById('ruletBoard');

        for(let c=0; c<12; c++){
            for(let r=0; r<3; r++){
                let n = satirDuzen[r][c];
                let d = document.createElement('div');
                d.className = `hucre ${kirmizilar.includes(n) ? 'kirmizi' : 'siyah'}`;
                d.innerHTML = `${n}<div class="para" id="p-${n}"></div>`;
                d.style.gridRow = r+1; d.style.gridColumn = c+2;
                d.onclick = () => analizEt(n);
                tahta.appendChild(d);
            }
        }

        function analizEt(n) {
            document.querySelectorAll('.para').forEach(p => p.style.display = 'none');
            const komsular = veriler[n];
            document.getElementById('sonuc').innerText = komsular;
            komsular.split('-').forEach(num => {
                const altin = document.getElementById(`p-${num.trim()}`);
                if(altin) altin.style.display = 'block';
            });
        }
    </script>
</body>
</html>
